{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": ["vite.config.ts", "drizzle.config.ts", "worker", "drizzle"]
}
