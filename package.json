{
  "name": "jcc-web-new",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "worker:dev": "npx wrangler dev --config wrangler.worker.toml",
    "worker:deploy": "npx wrangler deploy --config wrangler.worker.toml",
    "pages:dev": "npm run build && npx wrangler pages dev dist --compatibility-date=2026-06-18 --d1 DB=jcc_web_new --r2 SCREENSHOTS=jcc-web-new-screenshots",
    "pages:deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy-pages.ps1 -Branch main",
    "pages:deploy:preview": "powershell -ExecutionPolicy Bypass -File scripts/deploy-pages.ps1",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "npx wrangler d1 migrations apply jcc_web_new --local --config wrangler.worker.toml",
    "db:migrate:remote": "npx wrangler d1 migrations apply jcc_web_new --remote --config wrangler.worker.toml"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250617.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.3",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
